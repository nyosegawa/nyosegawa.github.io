<!doctype html>

<html lang="{{ it.lang }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ it.title || metas.title }} - {{ metas.site }}</title>

    <meta name="supported-color-schemes" content="light dark">
    <meta name="theme-color" content="hsl(220, 20%, 100%)" media="(prefers-color-scheme: light)">
    <meta name="theme-color" content="hsl(220, 20%, 10%)" media="(prefers-color-scheme: dark)">

    <link rel="stylesheet" href="/styles.css">
    <link rel="alternate" href="/feed.xml" type="application/atom+xml" title="{{ metas.site }}">
    <link rel="alternate" href="/feed.json" type="application/json" title="{{ metas.site }}">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png">
    <link rel="canonical" href="{{ url |> url(true) }}">
    <script src="/js/main.js" type="module"></script>
    {{ it.extra_head?.join("\n") }}
  </head>
  <body>
    <script>
      (function () {
        try {
          if (localStorage.getItem("lang-banner-dismissed") === "1") return;
        } catch (_) {}
        var pageLang = document.documentElement.lang || "ja";
        var langs = navigator.languages || [navigator.language || ""];
        var primary = (langs[0] || "").toLowerCase();
        var wantsEn = primary.indexOf("en") === 0;
        var wantsJa = primary.indexOf("ja") === 0;
        // Show only when the visitor's primary language differs from the page language
        var show = (pageLang === "ja" && wantsEn) || (pageLang === "en" && wantsJa);
        if (!show) return;
        var toggle = document.querySelector("a.lang-toggle");
        if (!toggle) return;
        var altHref = toggle.getAttribute("href");
        if (!altHref || altHref === "#") return;
        var banner = document.createElement("div");
        banner.className = "lang-banner";
        var msg, cta;
        if (pageLang === "ja") { msg = "English version available."; cta = "Read in English →"; }
        else { msg = "日本語版があります。"; cta = "日本語で読む →"; }
        banner.innerHTML = '<span class="lang-banner-msg"></span> <a class="lang-banner-cta"></a> <button class="lang-banner-close" aria-label="dismiss">×</button>';
        banner.querySelector(".lang-banner-msg").textContent = msg;
        var ctaLink = banner.querySelector(".lang-banner-cta");
        ctaLink.textContent = cta;
        ctaLink.setAttribute("href", altHref);
        var dismiss = function () { try { localStorage.setItem("lang-banner-dismissed", "1"); } catch (_) {} };
        banner.querySelector(".lang-banner-close").addEventListener("click", function () { banner.remove(); dismiss(); });
        ctaLink.addEventListener("click", dismiss);
        document.body.insertBefore(banner, document.body.firstChild);
      })();
    </script>
    <nav class="navbar">
      <a href="{{ it.lang == 'en' ? '/en/' : '/' }}" class="navbar-home">
        {{ if it.logo }}
          {{ it.logo }}
        {{ else }}
          <strong>{{ metas.site }}</strong>
        {{ /if }}
      </a>

      <ul class="navbar-links">
      {{- for entry of search.pages(`menu.visible=true lang=${it.lang || "ja"}`, "menu.order") }}
        <li>
          <a href="{{ entry.url }}"{{ if entry.url == url }} aria-current="page"{{ /if }}>
            {{ entry.menu.title || entry.title }}
          </a>
        </li>
      {{ /for }}
      {{- for link of it.menu_links }}
        <li>
          <a href="{{ link.href }}"{{ if link.target }} target="{{link.target}}"{{ /if }}>
            {{ link.text }}
          </a>
        </li>
      {{ /for }}
      <li>
        <a class="button lang-toggle" href="#" data-current-lang="{{ it.lang || 'ja' }}">{{ if it.lang == "en" }}JA{{ else }}EN{{ /if }}</a>
      </li>
      <li>
        <script>
          let theme = localStorage.getItem("theme") || (window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light");
          document.documentElement.dataset.theme = theme;
          function changeTheme() {
            theme = theme === "dark" ? "light" : "dark";
            localStorage.setItem("theme", theme);
            document.documentElement.dataset.theme = theme;
          }
        </script>
        <button class="button" onclick="changeTheme()">
          <span class="icon">◐</span>
        </button>
      </li>
      </ul>
    </nav>

    <main class="{{ it.bodyClass }}">
      {{ content }}
    </main>

    <!-- Current page: {{ url }} -->
  </body>
</html>
