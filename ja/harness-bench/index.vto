us 4.7 / max", "harness": "Claude Code", "runs": 27, "passed": 17, "failed": 10, "pass_rate": 0.6296296296296297, "median_wall_time_ms": 908918, "median_wall_time_min": 15.148633333333333, "cost_usd": 87.38012850000001, "cost_per_pass": 5.14000755882353, "timeouts": 2, "by_difficulty": {"low": {"runs": 9, "passed": 7, "pass_rate": 0.7777777777777778}, "mid": {"runs": 9, "passed": 4, "pass_rate": 0.4444444444444444}, "high": {"runs": 9, "passed": 6, "pass_rate": 0.6666666666666666}}}], "cases": [{"id": "axios-axios-high-http-connect-timeout", "repo": "axios/axios", "difficulty": "high", "size_bucket": "small", "instruction": ">", "selection_notes": ">", "pr_url": "https://github.com/axios/axios/pull/10819", "passed": 14, "runs": 14, "pass_rate": 1.0}, {"id": "axios-axios-low-settle-error-code", "repo": "axios/axios", "difficulty": "low", "size_bucket": "small", "instruction": ">", "selection_notes": ">", "pr_url": "https://github.com/axios/axios/pull/7276", "passed": 14, "runs": 14, "pass_rate": 1.0}, {"id": "axios-axios-mid-fetch-global-access", "repo": "axios/axios", "difficulty": "mid", "size_bucket": "small", "instruction": ">", "selection_notes": ">", "pr_url": "https://github.com/axios/axios/pull/7260", "passed": 14, "runs": 14, "pass_rate": 1.0}, {"id": "fastapi-fastapi-high-pydantic-json-fast-path", "repo": "fastapi/fastapi", "difficulty": "high", "size_bucket": "large", "instruction": ">", "selection_notes": ">", "pr_url": "https://github.com/fastapi/fastapi/pull/14962", "passed": 12, "runs": 14, "pass_rate": 0.8571428571428571}, {"id": "fastapi-fastapi-low-remove-vibe-decorator", "repo": "fastapi/fastapi", "difficulty": "low", "size_bucket": "large", "instruction": ">", "selection_notes": ">", "pr_url": "https://github.com/fastapi/fastapi/pull/15363", "passed": 14, "runs": 14, "pass_rate": 1.0}, {"id": "fastapi-fastapi-mid-jsonable-encoder-color-types", "repo": "fastapi/fastapi", "difficulty": "mid", "size_bucket": "large", "instruction": ">", "selection_no